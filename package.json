{
  "name": "docs",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "content:build": "tsx tools/content-build.ts",
    "start": "npm run content:build && ng serve",
    "build": "npm run content:build && ng build && tsx tools/postbuild.ts",
    "build:pages": "npm run content:build && ng build --base-href /docs/ && tsx tools/postbuild.ts",
    "watch": "npm run content:build && ng build --watch --configuration development",
    "test": "npm run content:build && ng test --no-watch",
    "test:coverage": "npm run content:build && ng test --no-watch --coverage"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "js-yaml": "^4.2.0",
    "marked": "^18.0.5",
    "rxjs": "~7.8.0",
    "shiki": "^4.2.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/platform-server": "^22.0.1",
    "@angular/ssr": "^22.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
